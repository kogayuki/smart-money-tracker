# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
DISCORD_SIGNAL_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Hyperliquid
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws

# Injective
INJECTIVE_INDEXER_URL=https://sentry.lcd.injective.network
INJECTIVE_GRPC_URL=https://sentry.chain.grpc-web.injective.network

# Database (Neon Postgres — optional, graceful degradation if unset)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Runtime
NODE_ENV=production
LOG_LEVEL=info
