# ── Discord ──
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
DISCORD_SIGNAL_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# ── Database (optional — runs without DB) ──
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ── Auto-Trader (Hyperliquid live trading) ──
AUTO_TRADER_ENABLED=false
AUTO_TRADER_EXCHANGE=hyperliquid
AUTO_TRADER_NETWORK=mainnet
# Your Hyperliquid wallet private key (0x-prefixed hex).
# This wallet must have USDC deposited on Hyperliquid.
# AUTO_TRADER_PRIVATE_KEY=0x...
AUTO_TRADER_COINS=BTC,ETH
AUTO_TRADER_POSITION_SIZE_USD=10
AUTO_TRADER_LEVERAGE=5
AUTO_TRADER_SLIPPAGE=0.02
AUTO_TRADER_MIN_CONFIDENCE=0.8
AUTO_TRADER_MAX_POSITIONS=3
AUTO_TRADER_SIGNAL_TYPES=flow_shift,confluence
# Hyperliquid builder fee (optional):
# AUTO_TRADER_BUILDER_ADDRESS=0x...
# AUTO_TRADER_BUILDER_FEE=0
# Injective fee recipient (optional — for Injective Agent Registry):
# AUTO_TRADER_FEE_RECIPIENT=inj1...

# ── Paper Trading ──
PAPER_ENABLED=true
PAPER_COINS=BTC,INJ
PAPER_POSITION_SIZE_USD=100
PAPER_TP_PCT=5
PAPER_SL_PCT=3
PAPER_MAX_HOLD_H=24
PAPER_MIN_CONFIDENCE=0.7
PAPER_SIGNAL_TYPES=flow_shift,confluence

# ── Runtime ──
NODE_ENV=production
LOG_LEVEL=info
